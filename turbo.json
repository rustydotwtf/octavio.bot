{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../packages/prompts/prompts/*.md"],
      "outputs": ["dist/**", "prompts/**", "public/**"]
    },
    "sync": {
      "inputs": ["$TURBO_DEFAULT$", "../../packages/prompts/prompts/*.md"],
      "outputs": ["prompts/**", "content/prompts-*.md"]
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    }
  }
}
