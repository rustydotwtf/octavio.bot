# Shared assistant runtime (API + Telegram)
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_api_key
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
ASSISTANT_MODEL=openai/gpt-5-mini
ASSISTANT_DB_PATH=.octavio/assistant.sqlite

# Assistant API
PORT=4100

# Telegram adapter
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_MODE=polling
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_IDLE_DELAY_MS=300

# Telegram webhook mode (optional)
# TELEGRAM_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://your-domain/telegram/webhook/replace-me
# TELEGRAM_WEBHOOK_SECRET=replace-me
# TELEGRAM_SET_WEBHOOK=false

# Review CLI / OpenCode (optional for assistant-only local usage)
# GITHUB_TOKEN=
# OPENCODE_HOSTNAME=
# OPENCODE_PORT=
# OPENCODE_API_KEY=
# OPENCODE_MODEL=
