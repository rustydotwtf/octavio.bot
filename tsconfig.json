{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@octavio.bot/prompts": ["packages/prompts/src/index.ts"],
      "@octavio.bot/assistant-core": ["packages/assistant-core/src/index.ts"],
      "@octavio.bot/agent-code-review": [
        "packages/agent-code-review/src/index.ts"
      ],
      "@octavio.bot/config": ["packages/config/src/index.ts"],
      "@octavio.bot/github-review": ["packages/github-review/src/index.ts"],
      "@octavio.bot/opencode-runner": ["packages/opencode-runner/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "apps/review-bot-cli/src/**/*.ts",
    "apps/assistant-api/src/**/*.ts",
    "packages/**/*.ts"
  ]
}
