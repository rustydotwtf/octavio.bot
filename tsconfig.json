{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@octavio/agent-code-review": ["packages/agent-code-review/src/index.ts"],
      "@octavio/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@octavio/config": ["packages/config/src/index.ts"],
      "@octavio/github-review": ["packages/github-review/src/index.ts"],
      "@octavio/opencode-runner": ["packages/opencode-runner/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
