{
  "name": "octavio-review",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=./apps/* --filter=./packages/* && bun x tsc --noEmit",
    "ci": "bun run check && bun run build && bun run test",
    "dev": "bun run site:dev",
    "assistant:dev": "bun run --cwd apps/assistant-api dev",
    "review-bot": "bun run apps/review-bot-cli/src/index.ts",
    "review-cli:build": "bun run --cwd apps/review-bot-cli build",
    "site:dev": "bun run --cwd apps/site watch:prompts & bun run --cwd apps/site dev",
    "site:sync:watch": "bun run --cwd apps/site watch:prompts",
    "sync": "turbo run sync --filter=./apps/* --filter=./packages/*",
    "check": "turbo run check --filter=./apps/* --filter=./packages/* && ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "test": "turbo run test --filter=./apps/* --filter=./packages/* && bun test"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.10",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "turbo": "^2.5.8",
    "ultracite": "7.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
